# ── Database ──────────────────────────────────────────────────────────────────
# Local: postgresql://tfy_user:tfy_pass@localhost:5432/tapeforyou
# Neon (prod): postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/tapeforyou?sslmode=require
DATABASE_URL=postgresql://tfy_user:tfy_pass@localhost:5432/tapeforyou

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash (prod): rediss://:password@host.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=change-me-min-32-chars-random-string-here
COOKIE_SECRET=change-me-min-32-chars-random-string-here
MEDUSA_BACKEND_URL=http://localhost:9000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local dev: include localhost ports
STORE_CORS=http://localhost:3000,http://localhost:3001
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:3000,http://localhost:9000

# Production (uncomment and set for prod):
# STORE_CORS=https://tapeforyou.com,https://www.tapeforyou.com
# ADMIN_CORS=https://admin.tapeforyou.com
# AUTH_CORS=https://tapeforyou.com,https://admin.tapeforyou.com

# ── Cloudflare R2 (File Storage) ─────────────────────────────────────────────
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=tapeforyou-media
R2_PUBLIC_URL=https://media.tapeforyou.com

# ── Stripe (Payment) ─────────────────────────────────────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=orders@tapeforyou.com

# ── Admin ─────────────────────────────────────────────────────────────────────
DISABLE_MEDUSA_ADMIN=false
