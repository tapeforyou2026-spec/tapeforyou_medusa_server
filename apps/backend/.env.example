# ── Database ──────────────────────────────────────────────────────────────────
# Local:      postgresql://tfy_user:tfy_pass@localhost:5432/tapeforyou
# Supabase:   postgresql://postgres.[ref]:[password]@[host].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://tfy_user:tfy_pass@localhost:5432/tapeforyou

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:   redis://localhost:6379
# Upstash: rediss://:password@host.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_HEX
COOKIE_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_HEX
MEDUSA_BACKEND_URL=http://localhost:9000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development
STORE_CORS=http://localhost:3000,http://localhost:3001,http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000,http://localhost:5173

# Production (set in Render dashboard, not here)
# STORE_CORS=https://tapeforyou.com,https://www.tapeforyou.com
# ADMIN_CORS=https://tapesforyou-backend.onrender.com
# AUTH_CORS=https://tapeforyou.com,https://tapesforyou-backend.onrender.com

# ── Admin ─────────────────────────────────────────────────────────────────────
DISABLE_MEDUSA_ADMIN=false

# ── Cloudflare R2 (File Storage — required in production) ─────────────────────
# npm install @medusajs/file-s3  then uncomment the module in medusa-config.ts
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=tapeforyou-media
R2_PUBLIC_URL=https://media.tapeforyou.com

# ── Stripe (Payment) ─────────────────────────────────────────────────────────
# npm install @medusajs/payment-stripe  then uncomment the module in medusa-config.ts
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=orders@tapeforyou.com
